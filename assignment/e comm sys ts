interface Product<T> {
  id: string;
  name: string;
  basePrice: number;
  category: T;
  getDiscountedPrice(discount: number): number;
}

interface PaymentMethod {
  processPayment(amount: number): Promise<boolean>;
  validatePayment(): boolean;
  getTransactionId(): string;
}

class BaseProduct implements Product<string> {
  constructor(
    public id: string,
    public name: string,
    public basePrice: number,
    public category: string
  ) {}

  getDiscountedPrice(discount: number): number {
    return this.basePrice - (this.basePrice * discount) / 100;
  }
}

class ElectronicsProduct extends BaseProduct {
  getDiscountedPrice(discount: number): number {
    let d = discount > 30 ? 30 : discount;
    return (this.basePrice - (this.basePrice * d) / 100) - 50;
  }
}

class ClothingProduct extends BaseProduct {
  getDiscountedPrice(discount: number): number {
    let d = discount > 50 ? 50 : discount;
    if (this.basePrice > 2000) d += 5;
    return this.basePrice - (this.basePrice * d) / 100;
  }
}

class Inventory<T extends Product<string>> {
  private items: T[] = [];

  addItem(item: T): void {
    this.items.push(item);
  }

  removeItem(id: string): boolean {
    const idx = this.items.findIndex(i => i.id === id);
    if (idx !== -1) {
      this.items.splice(idx, 1);
      return true;
    }
    return false;
  }

  findById(id: string): T | undefined {
    return this.items.find(i => i.id === id);
  }

  getAllItems(): T[] {
    return this.items;
  }
}

class CreditCardPayment implements PaymentMethod {
  private txId = "";
  constructor(private cardNum: string) {}

  validatePayment(): boolean {
    return this.cardNum.length === 16;
  }

  async processPayment(amount: number): Promise<boolean> {
    if (!this.validatePayment()) return false;
    this.txId = "CC-" + Math.floor(Math.random() * 1000);
    return true;
  }

  getTransactionId(): string {
    return this.txId;
  }
}

class PayPalPayment implements PaymentMethod {
  private txId = "";
  constructor(private email: string) {}

  validatePayment(): boolean {
    return this.email.includes("@");
  }

  async processPayment(amount: number): Promise<boolean> {
    if (!this.validatePayment()) return false;
    this.txId = "PP-" + Math.floor(Math.random() * 1000);
    return true;
  }

  getTransactionId(): string {
    return this.txId;
  }
}

class Order {
  private items: { product: Product<string>; quantity: number }[] = [];

  constructor(private paymentMethod: PaymentMethod, private discountPercent: number = 0) {}

  addProduct(product: Product<string>, quantity: number): void {
    this.items.push({ product, quantity });
  }

  calculateSubtotal(): number {
    return this.items.reduce((sum, item) => {
      return sum + (item.product.getDiscountedPrice(this.discountPercent) * item.quantity);
    }, 0);
  }

  async checkout(): Promise<{ success: boolean; transactionId: string }> {
    const total = this.calculateSubtotal();
    const success = await this.paymentMethod.processPayment(total);
    return {
      success,
      transactionId: success ? this.paymentMethod.getTransactionId() : "FAILED"
    };
  }
}